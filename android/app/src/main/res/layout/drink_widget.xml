<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="16dp"
  android:background="@drawable/widget_card_background">

  <TextView
    android:id="@+id/widget_title"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Super798 Widget"
    android:textAllCaps="true"
    android:textColor="#8A8A8A"
    android:textSize="10sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_device_name"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:text="先在设置里选设备"
    android:textColor="#FFFFFF"
    android:textSize="19sp"
    android:textStyle="bold" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/widget_scan_button"
      android:layout_width="0dp"
      android:layout_height="48dp"
      android:layout_weight="1"
      android:background="@drawable/widget_button_primary_background"
      android:gravity="center"
      android:text="扫码"
      android:textColor="#050505"
      android:textSize="15sp"
      android:textStyle="bold" />

    <Space
      android:layout_width="10dp"
      android:layout_height="1dp" />

    <TextView
      android:id="@+id/widget_drink_button"
      android:layout_width="0dp"
      android:layout_height="48dp"
      android:layout_weight="1"
      android:background="@drawable/widget_button_secondary_background"
      android:gravity="center"
      android:text="喝水"
      android:textColor="#FFFFFF"
      android:textSize="15sp"
      android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
